DJANGO_SECRET_KEY=change-me-before-production
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=api.example.com,127.0.0.1,localhost
DJANGO_CORS_ALLOWED_ORIGINS=https://frontend.vercel.app,http://localhost:5173,http://127.0.0.1:5173
DJANGO_CSRF_TRUSTED_ORIGINS=https://frontend.vercel.app,http://localhost:5173,http://127.0.0.1:5173
DJANGO_SQLITE_PATH=/data/db.sqlite3
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1
DJANGO_SESSION_COOKIE_SAMESITE=None
DJANGO_CSRF_COOKIE_SAMESITE=None
DJANGO_TRUST_X_FORWARDED_PROTO=1
DJANGO_USE_X_FORWARDED_HOST=1
